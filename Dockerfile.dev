# Pinned by digest (tag: 25-jdk-alpine = JDK 25.0.3+9). Refresh as described in
# the comment at the top of ./Dockerfile when taking security patches.
FROM eclipse-temurin:25-jdk-alpine@sha256:30d9f87d702c2c1c601ed0d31e0c88ea1ea474ee7676cda7b7a59e759181c4dd

# Install essential development tools (full JDK 25 comes from the base image)
RUN apk add --no-cache \
    bash \
    curl \
    wget \
    jq \
    dcron \
    rsync \
    sudo

# Environment variables
ENV MC_VERSION="latest" \
    PAPER_BUILD="latest" \
    EULA="true" \
    MC_RAM="" \
    JAVA_OPTS=""

# Create a non-root user for development
ARG USERNAME=minecraft

RUN addgroup -S $USERNAME && \
    adduser -S -G $USERNAME $USERNAME && \
    echo "$USERNAME ALL=(ALL) NOPASSWD: /usr/sbin/crond, /usr/bin/crontab" > /etc/sudoers.d/$USERNAME && \
    chmod 0440 /etc/sudoers.d/$USERNAME

# Create required directories (incl. the /workspace WORKDIR) owned by the dev
# user, so it can read/write them when the container runs as a non-root user.
RUN mkdir /papermc /backups /logs /workspace \
    && chown -R $USERNAME:$USERNAME /papermc /backups /logs /workspace

COPY start-backup.sh /scripts/
RUN chmod +x /scripts/*.sh

# Set the default user
USER $USERNAME

# Set working directory
WORKDIR /workspace

# Default command
CMD ["/bin/bash"]

# Container setup
EXPOSE 25565/tcp
EXPOSE 25565/udp
VOLUME /papermc
VOLUME /logs
VOLUME /backups