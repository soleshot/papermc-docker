# Keep LF line endings on files that run inside the Linux container, on every
# OS and regardless of git's core.autocrlf. A Windows checkout with autocrlf=true
# otherwise rewrites these to CRLF, and the COPYed shell scripts then fail at
# runtime with: /papermc.sh: line 2: $'\r': command not found
*.sh          text eol=lf
Dockerfile    text eol=lf
Dockerfile.*  text eol=lf
*.properties  text eol=lf

# PowerShell helper is Windows-only; leave it CRLF.
*.ps1         text eol=crlf
